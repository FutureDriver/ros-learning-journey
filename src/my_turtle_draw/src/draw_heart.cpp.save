/**
 * draw_heart.cpp
 * 控制 turtlesim 中的小乌龟画一个爱心
 * 编译: catkin_make 或 g++ 手动编译
 * 运行: rosrun <my_turtle_draw> draw_heart_node
 */

#include <ros/ros.h>
#include <geometry_msgs/Twist.h>
#include <cmath>
#include <unistd.h>
#include <iostream>

int main(int argc, char **argv)
{
    // 1. 初始化ROS节点
    ros::init(argc, argv, "draw_heart_node");  os::NodeHandle nh;

    // 2. 创建Publisher，发布到 /turtle1/cmd_vel 话题
    ros::Publisher pub = nh.advertise<geometry_msgs::Twist>("/turtle1/cmd_vel", 10);  // 修正：使用英文双引号

    // 3. 等待与 turtlesim_node 建立连接
    // 确保有订阅者后再发送数据，避免消息丢失
    sleep(1);
    ROS_INFO("开始绘制爱心...");  // 修正：使用英文双引号

    // 4. 设置循环频率 (Hz)
    ros::Rate loop_rate(50);  // 提高频率以获得更平滑的轨迹

    // 5. 心形线参数 (直角坐标系参数方程)
    double a = 2.0;          // 爱心大小
    double t = 0.0;          // 参数t
    double delta_t = 0.05;   // 参数增量
    
    // 用于计算速度和角度的变量
    double last_x = 0, last_y = 0;
    bool first_point = true;

    // 6. 主循环：计算并发布速度指令
    while (t < 2 * M_PI && ros::ok())
    {
        // 心形线的参数方程
        double x = a * (16 * pow(sin(t), 3));
        double y = a * (13 * cos(t) - 5 * cos(2*t) - 2 * cos(3*t) - cos(4*t));
        
        // 计算速度方向
        if (!first_point) {
            // 创建速度消息对象
            geometry_msgs::Twist twist_msg;
            
            // 计算前进方向
            double dx = x - last_x;
            double dy = y - last_y;
            double distance = sqrt(dx*dx + dy*dy);
            
            // 计算角度
            double target_angle = atan2(dy, dx);
            
            // 设置线速度和角速度
            twist_msg.linear.x = distance * 2.0;  // 乘以系数以获得合适的速度
            twist_msg.linear.y = 0.0;
            twist_msg.linear.z = 0.0;
            twist_msg.angular.x = 0.0;
            twist_msg.angular.y = 0.0;
            twist_msg.angular.z = 0.0;  // 简化：不控制角速度
            
            // 发布消息
            pub.publish(twist_msg);
            
            ROS_INFO("t=%.2f, x=%.2f, y=%.2f, v=%.2f", t, x, y, twist_msg.linear.x);
        }
        
        // 更新上一位置
        last_x = x;
        last_y = y;
        first_point = false;
        
        // 更新参数
        t += delta_t;
        
        // 按照循环频率延时
        loop_rate.sleep();
        ros::spinOnce();
    }

    // 7. 绘制完成后发送停止指令
    geometry_msgs::Twist stop_msg;
    pub.publish(stop_msg);
    ROS_INFO("爱心绘制完成！");  // 修正：使用英文双引号
    
    // 等待一会儿，让消息发布出去
    ros::Duration(1.0).sleep();

    return 0;
}
